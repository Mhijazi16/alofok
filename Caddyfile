{$DOMAIN:localhost} {
    # API proxy
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy backend:8000
    }

    # Uploaded files (product images, avatars, check photos) served straight from
    # the shared static_files volume — not proxied through the API workers.
    # Filenames are content UUIDs and never change, so cache them aggressively.
    handle_path /static/* {
        root * /srv/static
        header Cache-Control "public, max-age=31536000, immutable"
        file_server
    }

    # SPA — serve built frontend, fallback to index.html
    handle {
        root * /srv

        # Hashed asset bundles are content-addressed (filename changes on every
        # build), so they are safe to cache forever.
        @immutable path /assets/*
        header @immutable Cache-Control "public, max-age=31536000, immutable"

        # The HTML entry point and service-worker files must always revalidate,
        # otherwise a returning browser keeps an old index.html that references
        # chunk hashes deleted by the latest deploy (dynamic-import failures).
        header /index.html Cache-Control "no-cache, must-revalidate"
        header /sw.js Cache-Control "no-cache, must-revalidate"
        header /registerSW.js Cache-Control "no-cache, must-revalidate"
        header /manifest.webmanifest Cache-Control "no-cache, must-revalidate"

        try_files {path} /index.html
        file_server
    }

    encode gzip
}
